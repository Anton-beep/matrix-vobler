# Configuration file for Synapse.
#
# This is a YAML file: see [1] for a quick introduction. Note in particular
# that *indentation is important*: all the elements of a list or dictionary
# should have the same indentation.
#
# [1] https://docs.ansible.com/ansible/latest/reference_appendices/YAMLSyntax.html
#
# For more information on how to configure Synapse, including a complete accounting of
# each option, go to docs/usage/configuration/config_documentation.md or
# https://element-hq.github.io/synapse/latest/usage/configuration/config_documentation.html
server_name: "matrix.vobler-tech.space:4444"
# pid_file: /data/homeserver.pid
listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    resources:
      - names: [client, federation]
        compress: false
database:
  name: psycopg2
  args:
    user: "synapse"
    password: "{{ SYNAPSE_DB_PASSWORD }}"
    host: "db"
    cp_min: 5
    cp_max: 10
matrix_authentication_service:
  enabled: true
  endpoint: "http://matrix-authentication-service:8080"
  secret: "{{ MATRIX_AUTH_SERVICE_SECRET }}"
user_directory:
  enabled: false
log_config: "/data/vobler-tech.space.log.config"
media_store_path: /data/media_store
report_stats: true
macaroon_secret_key: "{{ MACAROON_SECRET_KEY }}"
trusted_key_servers:
  - server_name: "matrix.org"
auto_join_rooms:
  - "#ℹ️volber-tech-homeserver-info:matrix.vobler-tech.space:4444"
  - "#📢volber-tech-homeserver-announcements:matrix.vobler-tech.space:4444"
autocreate_auto_join_rooms: true
experimental_features:
  msc3266_enabled: true
  msc4222_enabled: true
max_event_delay_duration: 24h
rc_message:
  # This needs to match at least e2ee key sharing frequency plus a bit of headroom
  # Note key sharing events are bursty
  per_second: 0.5
  burst_count: 30
rc_delayed_event_mgmt:
  # This needs to match at least the heart-beat frequency plus a bit of headroom
  # Currently the heart-beat is every 5 seconds which translates into a rate of 0.2s
  per_second: 1

  burst_count: 20
